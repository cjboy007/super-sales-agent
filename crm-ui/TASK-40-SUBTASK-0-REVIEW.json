  "risks_and_mitigation": {
    "sqlite_json_support": {
      "risk": "SQLite 版本 < 3.38 不支持 JSON 函数，无法直接解析 product_list 字段",
      "mitigation": "方案 A：升级 SQLite 到 3.38+；方案 B：在应用层解析 JSON（Node.js JSON.parse）；方案 C：将产品分析列为 P1 优先级，后续迭代实现。"
    },
    "large_dataset_performance": {
      "risk": "订单量 > 10000 时，聚合查询可能变慢",
      "mitigation": "1) 使用现有索引（status、created_at、company_id）；2) 添加物化视图或预计算表（daily_stats）；3) 限制最大查询范围（最多 90 天）；4) 分页加载。"
    },
    "pdf_export_complexity": {
      "risk": "@react-pdf/renderer 学习曲线陡峭，布局复杂",
      "mitigation": "方案 A：使用 html2pdf.js（基于 html2canvas+jsPDF，简单但质量略低）；方案 B：后端生成（Puppeteer 渲染 HTML 转 PDF，质量高但依赖 Chrome）；推荐方案 A 快速上线。"
    },
    "real_time_data_sync": {
      "risk": "分析数据与订单数据不同步（缓存导致）",
      "mitigation": "1) 不缓存，实时查询（订单量 < 10000 可接受）；2) 添加刷新按钮手动刷新；3) 订单创建/更新后触发分析数据更新（webhook 或事件驱动）。"
    }
  },
  
  "feedback": "技术方案清晰可行，数据库基础已就绪（task-38 完成），可直接开始开发。推荐技术栈：Recharts（图表）+ XLSX（Excel 导出）+ html2pdf.js（PDF 导出），均为成熟库，文档完善。关键设计决策：1) 优先实现 P0 报表（概览/状态分布/销售趋势），P1 报表（客户/产品分析）可延后；2) 导出功能先支持 Excel/CSV（简单），PDF 可迭代优化；3) 产品分析依赖 JSON 解析，如 SQLite 版本受限，改用应用层解析。建议开发顺序：Phase 1（安装依赖 + API 框架）→ Phase 2（后端 API）→ Phase 3（前端图表）→ Phase 4（测试），与 task-39 回款模块并行开发时注意代码复用（API 路由模式、组件结构）。",
  
