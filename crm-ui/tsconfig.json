{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "resolveJsonModule": true
  },
  "include": [
    "utils/*.ts",
    "db/*.ts",
    "enums/*.ts"
  ],
  "exclude": ["node_modules"]
}
