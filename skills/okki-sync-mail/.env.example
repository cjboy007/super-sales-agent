# IMAP Configuration (receiving email)
IMAP_HOST=your_imap_host.com
IMAP_PORT=993
IMAP_USER=your-email@your-domain.com
IMAP_PASS=your_authorization_code_here
IMAP_TLS=true

# SMTP Configuration (sending email)
SMTP_HOST=your_smtp_host.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@your-domain.com
SMTP_PASS=your_authorization_code_here
SMTP_FROM=your-email@your-domain.com

# Sender Name (for signature replacement)
# This name will replace "[Your Name]" in email signatures
SMTP_SENDER_NAME=Your Name

# Rate Limiting (emails per hour)
SMTP_RATE_LIMIT=50

# OKKI Integration
OKKI_CLI_PATH=/path/to/your/xiaoman-okki/api/okki_cli.py
VECTOR_SEARCH_PATH=/path/to/your/vector_store/okki_vector_search_v3.py

# Allowed Directories (for file read operations)
ALLOWED_READ_DIRS=/path/to/your/workspace
