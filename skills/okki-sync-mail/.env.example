# IMAP/SMTP Email Configuration

# IMAP Configuration (receiving email)
# 网易企业邮 (NetEase Enterprise Email)
IMAP_HOST=imaphz.qiye.163.com
IMAP_PORT=993
IMAP_USER=sale-9@farreach-electronic.com
IMAP_PASS=your_imap_password_here  # ⚠️ REPLACE with your real IMAP authorization code
IMAP_TLS=true
IMAP_REJECT_UNAUTHORIZED=true
IMAP_MAILBOX=INBOX

# SMTP Configuration (sending email)
SMTP_HOST=smtphz.qiye.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sale-9@farreach-electronic.com
SMTP_PASS=your_smtp_password_here  # ⚠️ REPLACE with your real SMTP authorization code
SMTP_FROM=sale-9@farreach-electronic.com
SMTP_REJECT_UNAUTHORIZED=true

# Sender Name (for signature replacement)
# This name will replace "[Your Name]" in email signatures
SMTP_SENDER_NAME=Your Name

# Rate Limiting (emails per hour)
SMTP_RATE_LIMIT=50

# OKKI CRM Integration (optional)
OKKI_CLI_PATH=/Users/wilson/.openclaw/workspace/xiaoman-okki/api/okki_cli.py
VECTOR_SEARCH_PATH=/Users/wilson/.openclaw/workspace/vector_store/okki_vector_search_v3.py

# Allowed Directories (for file read operations)
ALLOWED_READ_DIRS=/Users/wilson/.openclaw/workspace

# Allowed Directories (for file write operations)
ALLOWED_WRITE_DIRS=/Users/wilson/.openclaw/workspace/mail-archive,/Users/wilson/.openclaw/workspace/skills/imap-smtp-email/drafts,/Users/wilson/.openclaw/workspace/skills/imap-smtp-email/scheduled
